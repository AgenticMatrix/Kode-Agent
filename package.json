{
  "name": "coder-agent",
  "version": "0.1.0",
  "description": "CoderAgent — A fully open-source AI programming assistant for the terminal",
  "type": "module",
  "bin": {
    "coder": "./bin/coder.js"
  },
  "scripts": {
    "start": "tsx src/cli/main.tsx",
