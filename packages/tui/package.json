{
  "name": "@coder/tui",
  "version": "0.1.0",
  "description": "Coder Agent TUI framework — React Ink-based terminal renderer with Yoga Layout",
  "type": "module",
  "main": "./dist/entry-exports.js",
  "types": "./dist/entry-exports.d.ts",
  "exports": {
    ".": {
      "types": "./dist/entry-exports.d.ts",
      "default": "./dist/entry-exports.js"
    },
    "./text-input": {
      "types": "./dist/text-input.d.ts",
      "default": "./dist/text-input.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run"
  },
  "peerDependencies": {
    "ink-text-input": ">=6.0.0",
    "react": ">=19.0.0"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.1.0",
    "auto-bind": "^5.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "bidi-js": "^1.0.0",
    "chalk": "^5.4.0",
    "cli-boxes": "^3.0.0",
    "code-excerpt": "^4.0.0",
    "emoji-regex": "^10.4.0",
    "get-east-asian-width": "^1.3.0",
    "indent-string": "^5.0.0",
    "lodash-es": "^4.17.0",
    "react": ">=19.0.0",
    "react-compiler-runtime": "^1.0.0",
    "react-reconciler": "0.33.0",
    "semver": "^7.6.0",
    "signal-exit": "^4.1.0",
    "stack-utils": "^2.0.0",
    "string-width": "^8.2.1",
    "strip-ansi": "^7.1.0",
    "supports-hyperlinks": "^3.1.0",
    "type-fest": "^4.30.0",
    "usehooks-ts": "^3.1.0",
    "wrap-ansi": "^9.0.0"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^19.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
